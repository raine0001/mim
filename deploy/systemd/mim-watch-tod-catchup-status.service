[Unit]
Description=MIM Watch TOD Catch-up Status
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=testpilot
Group=testpilot
WorkingDirectory=/home/testpilot/mim
Environment=POLL_SECONDS=30
Environment=MAX_STATUS_AGE_SECONDS=900
Environment=CONSECUTIVE_PASS_TARGET=3
ExecStart=/home/testpilot/mim/scripts/watch_tod_catchup_status.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mim
APP_NAME=MIM Core
APP_VERSION=0.1.0
ENVIRONMENT=local
ALLOW_OPENAI=false
ALLOW_WEB_ACCESS=false
ALLOW_LOCAL_DEVICES=true

# Automation/browser
AUTOMATION_ENABLED=true
AUTOMATION_DEFAULT_SIMULATION=true
AUTOMATION_ALLOW_LIVE_BROWSER=false
AUTOMATION_BROWSER_HEADLESS=true
AUTOMATION_STORAGE_DIR=/home/testpilot/mim/runtime/automation
AUTOMATION_DEFAULT_TIMEOUT_SECONDS=20

# SMTP (outbound)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=

# IMAP (inbound MFA/report mail reading)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_INBOX=INBOX

# Optional SMS placeholders
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=
